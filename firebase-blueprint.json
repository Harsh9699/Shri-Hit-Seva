{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with devotion tracking or settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "isSubscribed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Message": {
      "title": "Message",
      "description": "Devotional chat message inside the satsang rooms",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "senderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reactions": { "type": "object" }
      },
      "required": ["content", "senderName", "senderAvatar", "senderId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/community_rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Satsang custom chat rooms message lists"
    }
  }
}
